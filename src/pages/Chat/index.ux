        <text class="more-label">更多功能</text>
      </div>
    </div>

    <!-- 输入栏 -->
<div class="input-bar">
  <input class="input-field" 
         type="text" 
         placeholder="告诉我你的需求吧～" 
         value="{{inputText}}" 
        @change="onInput" />
  <!-- <text class="emoji-btn">🙂</text> -->
  <div class="send-btn" @click="onSend">
    <text class="send-icon">➤</text>
  </div>
</div>

  </div>
</template>

<script>

// import { execSQL } from '../../js/db.js'

export default {
  data() {
  const now = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })
  return {
    greetingTime1:now,
    messages: [],
    currentCity: '上海',
    cityData: null,
    inputText: '' ,   // ← 新增这一行
    tripData: {
      startPlace: '杭州东站',
      endPlace: '上海虹桥站',
      startTime: '10:00',
      endTime: '11:02',
      remainTime: 32,
      arriveTime: '11:02',
      progress: 60
    }
  }
},

// 处理输入框变化
onInput(e) {
  this.inputText = e.value
},

// 点击发送按钮
onSend() {
  const text = this.inputText.trim()
  if (!text) return
  this.sendMessage(text)
  this.inputText = ''   // 清空输入框
},
  // ✅ 改用 onReady，更稳定
  async onReady() {
    await this.loadHistory()
    await this.loadCityData()
    console.log('✅ 页面初始化完成')
  },

  // 加载历史消息
  async loadHistory() {
    try {
      const sql = `SELECT * FROM chat_history ORDER BY timestamp ASC LIMIT 50`
      const result = await execSQL(sql)
      if (result.rows) {
        this.messages = result.rows.map(row => ({
          role: row.role,
          content: row.content,
          time: row.timestamp
        }))
      }
      console.log('✅ 加载历史消息成功，共', this.messages.length, '条')
    } catch (err) {
      console.error('❌ 加载历史失败', err)
    }
  },

  // 加载城市数据
  async loadCityData() {
    try {
      // const sql = `SELECT * FROM city_data WHERE city_name = ?`
      const result = await execSQL(sql, [this.currentCity])
      if (result.rows && result.rows.length > 0) {
        const data = result.rows[0]
        this.cityData = {
          attractions: JSON.parse(data.attractions),
          tips: JSON.parse(data.tips),
          food: JSON.parse(data.food)
        }
        console.log('✅ 加载城市数据成功', this.cityData)
      }
    } catch (err) {
      console.error('❌ 加载城市数据失败', err)
    }
  },

  // 保存消息
  async saveMessage(role, content) {
    // try {
    //   const sql = `
    //     INSERT INTO chat_history (role, content, timestamp, synced)
    //     VALUES (?, ?, ?, 0)
    //   `
    //   await execSQL(sql, [role, content, new Date().toISOString()])
    // } catch (err) {
    //   console.error('❌ 保存消息失败', err)
    // }
  },

  // 发送消息
async sendMessage(input) {
  if (!input) return

  // ✅ 用户消息：使用当前时间
  const now = new Date()
  const timeStr = now.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })
  
  this.messages.push({ 
    role: 'user', 
    content: input, 
    time: timeStr 
  })

  // 调用 AI...
  const reply = await this.callAI(input)
  
  // ✅ AI回复：也使用当前时间（或者用同一个 now）
  this.messages.push({ 
    role: 'assistant', 
    content: reply, 
    time: new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })
  })
},

  // 离线回答
  getOfflineReply(input) {
    let reply = '🕊️ 团团离线提示：'
    if (input.includes('景点') || input.includes('玩')) {
      reply += `\n推荐景点：${this.cityData?.attractions?.join('、') || '外滩、豫园'}`
    } else if (input.includes('吃') || input.includes('美食')) {
      reply += `\n推荐美食：${this.cityData?.food?.join('、') || '小笼包、生煎'}`
    } else {
      reply += `\n当前在${this.currentCity}，有需要随时问我~`
    }
    this.messages.push({ role: 'assistant', content: reply, time: new Date().toLocaleString() })
    this.saveMessage('assistant', reply)
  },

  // 调用后端AI
  async callAI(input) {
    try {
      const res = await fetch('http://localhost:3000/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ msg: input })
      })
      const data = await res.json()
      return data.reply || '团团暂时走神了，再问一次吧~'
    } catch (err) {
      console.error('调用AI失败', err)
      throw err
    }
  }
}
</script>


