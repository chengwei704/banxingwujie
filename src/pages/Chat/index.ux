<template>
  <div class="page">

    <!-- 导航栏 -->
    <div class="nav">
      <div class="brand">
        <text class="brand-star">✦</text>
        <text class="brand-name">团团</text>
        <div class="brand-tag">
          <text class="brand-tag-text">陪你每一程</text>
        </div>
      </div>
      <div class="nav-icons">
        <text class="nav-icon-clock">○</text>
        <text class="nav-icon-menu">⋮</text>
      </div>
    </div>

    <!-- 滚动内容区 -->
  <!-- 滚动内容区 -->
  <div class="scroll-area" style="flex:1;">
<div class="scroll-inner">
  <!-- 1. 问候语 + 卡片（固定显示） -->
  <div class="msg-row">
    <div class="avatar">
      <image class="avatar-img" src="/assets/images/avatar.png"></image>
    </div>
    <div class="bubble-wrap">
      <div class="bubble">
        <text class="bubble-text">你好！我是你的旅行伙伴 TripPal ✨{{'\n'}}无论网络如何，我都会陪伴你{{'\n'}}让每一段旅程都安心又愉快</text>
      </div>
      <text class="bubble-time">{{greetingTime1}}</text>
    </div>
  </div>

  <!-- 行程卡片 -->
  <div class="card-wrap">
    <trip-card></trip-card>
  </div>

  <!-- 环境卡片 -->
  <div class="card-wrap">
    <env-card></env-card>
  </div>

  <!-- 2. 动态消息列表（用户发送的消息显示在这里） -->
  <div class="msg-row" for="(index, msg) in messages">
    <!-- AI消息：靠左 -->
    <div class="msg-left" if="{{msg.role === 'assistant'}}">
      <div class="avatar">
        <image class="avatar-img" src="/assets/images/avatar.png"></image>
      </div>
      <div class="bubble-wrap">
        <div class="bubble"><text class="bubble-text">{{msg.content}}</text></div>
        <text class="bubble-time">{{msg.time}}</text>
      </div>
    </div>
    <!-- 用户消息：靠右 -->
    <div class="msg-right" if="{{msg.role === 'user'}}">
      <div class="bubble-wrap">
        <div class="bubble-user"><text class="bubble-text">{{msg.content}}</text></div>
        <text class="bubble-time" style="text-align: right;">{{msg.time}}</text>
      </div>
    </div>
  </div>

  <div class="bottom-space"></div>
</div>
</div>

    <!-- 快捷功能栏 -->
    <div class="quick-bar">
      <div class="quick-item">
        <div class="quick-icon-wrap">
          <text class="quick-icon-text">🔔</text>
        </div>
